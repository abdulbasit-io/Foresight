# Copy to .env and fill in after deploying both contracts

# Deployed PredictionMarket contract address
VITE_PREDICTION_MARKET_CONTRACT=

# Deployed TestWBTC contract address (users call faucet() to get tokens)
VITE_TEST_WBTC_CONTRACT=

# Your Bitcoin wallet address (bc1p... / tb1p...) — identifies you as the platform
# resolver in the UI so the resolve panel shows your role correctly.
# The contract uses your on-chain public key hash, not this string directly,
# but the UI uses it to label your vote row as "Foresight (Platform)".
VITE_PLATFORM_RESOLVER=
